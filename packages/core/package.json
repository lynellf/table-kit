{
  "name": "@lynellf/tablekit-core",
  "version": "1.1.0",
  "private": false,
  "description": "Headless table state engine, row pipeline, column model, and event system.",
  "type": "module",
  "main": "./dist/tablekit-core.es.js",
  "module": "./dist/tablekit-core.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/tablekit-core.es.js"
    },
    "./virtualization": {
      "types": "./dist/virtualization/index.d.ts",
      "import": "./dist/virtualization/index.es.js"
    },
    "./resize": {
      "types": "./dist/resize.d.ts",
      "import": "./dist/resize.es.js"
    },
    "./pinning": {
      "types": "./dist/pinning.d.ts",
      "import": "./dist/pinning.es.js"
    },
    "./keyboard-nav": {
      "types": "./dist/keyboardNav.d.ts",
      "import": "./dist/keyboard-nav.es.js"
    },
    "./memo": {
      "types": "./dist/pipeline/memo.d.ts",
      "import": "./dist/pipeline/memo.es.js"
    },
    "./dataSource": {
      "types": "./dist/dataSource/index.d.ts",
      "import": "./dist/dataSource/index.es.js"
    },
    "./announcer": {
      "types": "./dist/announcer.d.ts",
      "import": "./dist/announcer.es.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lynellf/table-kit"
  },
  "bugs": {
    "url": "https://github.com/lynellf/table-kit/issues"
  },
  "homepage": "https://github.com/lynellf/table-kit",
  "keywords": ["table", "headless", "data-grid", "state-machine", "virtualization"],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "vite build && pnpm build:types",
    "build:types": "tsc -p tsconfig.build.json",
    "build:subpaths": "node vite.subpaths.config.mjs",
    "typecheck": "tsc -b"
  },
  "devDependencies": {},
  "peerDependencies": {}
}
