{
  "name": "@lynellf/tablekit-react",
  "version": "2.0.0",
  "private": false,
  "description": "React adapter for @lynellf/tablekit-core — hooks, prop getters, announcer, and a11y validator.",
  "type": "module",
  "main": "./dist/tablekit-react.es.js",
  "module": "./dist/tablekit-react.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/tablekit-react.es.js"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "import": "./dist/validate.es.js"
    },
    "./styles.css": "./dist/style.css"
  },
  "files": ["dist", "docs"],
  "sideEffects": ["**/*.css"],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lynellf/table-kit"
  },
  "bugs": {
    "url": "https://github.com/lynellf/table-kit/issues"
  },
  "homepage": "https://github.com/lynellf/table-kit",
  "keywords": ["react", "table", "headless", "data-grid", "hooks"],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "vite build && pnpm build:types && pnpm copy:guides",
    "build:types": "tsc -p tsconfig.build.json",
    "copy:guides": "node -e \"const{cpSync,existsSync,mkdirSync}=require('fs');const d='../../docs/guides';if(existsSync(d)){mkdirSync('docs',{recursive:true});cpSync(d,'docs/guides',{recursive:true});console.log('\\u2713 Copied docs/guides into package');}\"",
    "build:subpaths": "node vite.subpaths.config.mjs",
    "typecheck": "tsc -b"
  },
  "peerDependencies": {
    "@lynellf/tablekit-core": "^2.0.0",
    "@lynellf/tablekit-pivot": "^2.0.0",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@lynellf/tablekit-pivot": { "optional": true }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "jsdom": "^25.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
