{
  "name": "@lynellf/tablekit-react",
  "version": "0.1.0",
  "private": false,
  "description": "React adapter for @lynellf/tablekit-core — hooks, prop getters, announcer, and a11y validator.",
  "type": "module",
  "main": "./dist/tablekit-react.es.js",
  "module": "./dist/tablekit-react.es.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/tablekit-react.es.js"
    },
    "./validate": {
      "types": "./dist/validate.d.ts",
      "import": "./dist/validate.es.js"
    }
  },
  "files": ["dist"],
  "sideEffects": false,
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/lynellf/tablekit"
  },
  "bugs": {
    "url": "https://github.com/lynellf/tablekit/issues"
  },
  "homepage": "https://github.com/lynellf/tablekit",
  "keywords": ["react", "table", "headless", "data-grid", "hooks"],
  "engines": {
    "node": ">=20.0.0"
  },
  "scripts": {
    "build": "vite build",
    "build:subpaths": "node vite.subpaths.config.mjs",
    "typecheck": "tsc -b"
  },
  "peerDependencies": {
    "@lynellf/tablekit-core": "workspace:*",
    "@lynellf/tablekit-pivot": "workspace:*",
    "react": ">=18.0.0"
  },
  "peerDependenciesMeta": {
    "@lynellf/tablekit-pivot": { "optional": true }
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.0",
    "@testing-library/react": "^16.3.2",
    "@types/react": "^18.3.12",
    "jsdom": "^25.0.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7"
  }
}
