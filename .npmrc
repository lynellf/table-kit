# ─── Workspace development flags ───────────────────────────────────────────────
# These are used by `pnpm install` in the local dev environment.
# They are NOT read during `npm publish` (publish reads publishConfig instead).
# DO NOT add `//registry.npmjs.org/:_authToken` here — keep tokens in
# `~/.npmrc` (never committed) or your CI secret manager.
# ───────────────────────────────────────────────────────────────────────────────
link-workspace-packages=true
prefer-workspace-packages=true
save-workspace-protocol=rolling
strict-peer-dependencies=false
auto-install-peers=true
node-linker=isolated
